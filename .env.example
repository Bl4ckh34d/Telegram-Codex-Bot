TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
ALLOW_GROUP_CHAT=0
# Foreground guard: refuse to run when no interactive terminal is attached.
# Set to 0 only if you intentionally run it as a background/service process.
BOT_REQUIRE_TTY=1
# Shutdown on SIGHUP signal (default 0 on Windows, 1 on non-Windows).
# Set to 1 if your process manager intentionally uses SIGHUP for restarts.
BOT_EXIT_ON_SIGHUP=0
CODEX_BIN=codex
CODEX_USE_WSL=auto
CODEX_WSL_BIN=
CODEX_WORKDIR=C:\Users\ROG
CODEX_DANGEROUS_FULL_ACCESS=1
CODEX_SANDBOX=danger-full-access
CODEX_APPROVAL_POLICY=never
CODEX_TIMEOUT_MS=0
CODEX_MODEL=gpt-5.3-codex
# Optional extra models shown in /model picker (comma-separated).
CODEX_MODEL_CHOICES=gpt-5.3-codex,gpt-5.2-codex,gpt-5.1-codex
CODEX_REASONING_EFFORT=medium
CODEX_PROFILE=
CODEX_EXTRA_ARGS=
CODEX_PROMPT_FILE=codex_prompt.txt
CODEX_VOICE_PROMPT_FILE=codex_prompt_voice.txt
ORCH_MAX_CODEX_WORKERS=5
ORCH_ROUTER_ENABLED=1
ORCH_ROUTER_MAX_CONCURRENCY=2
ORCH_ROUTER_TIMEOUT_MS=0
ORCH_ROUTER_MODEL=
ORCH_ROUTER_REASONING_EFFORT=low
ORCH_ROUTER_PROMPT_FILE=codex_prompt_router.txt
# Persistent failure-learning memory for reducing repeated mistakes.
ORCH_LESSONS_ENABLED=1
ORCH_LESSONS_MAX_ITEMS=240
ORCH_LESSONS_PER_PROMPT=4
ORCH_LESSONS_PROMPT_MAX_CHARS=1200
ORCH_LESSON_MAX_TEXT_CHARS=220
ORCH_LESSON_TTL_DAYS=45
WORLDMONITOR_MONITOR_ENABLED=0
WORLDMONITOR_NATIVE_FEEDS_PATH=worldmonitor_native_feeds.json
WORLDMONITOR_MONITOR_INTERVAL_SEC=300
# Interval alert output mode for scheduled monitor runs: smart | headlines | report | off
WORLDMONITOR_INTERVAL_ALERT_MODE=smart
# In smart/headlines mode, only forward headline links when global level is at or above this severity.
WORLDMONITOR_INTERVAL_HEADLINES_MIN_LEVEL=critical
WORLDMONITOR_STARTUP_DELAY_SEC=25
# Native feed fetch tuning
WORLDMONITOR_NATIVE_FEED_TIMEOUT_MS=9000
WORLDMONITOR_NATIVE_FEED_FETCH_CONCURRENCY=10
WORLDMONITOR_NATIVE_FEED_ITEMS_PER_SOURCE=24
WORLDMONITOR_NATIVE_STORE_MAX_ITEMS=16000
WORLDMONITOR_NATIVE_STORE_MAX_AGE_DAYS=30
WORLDMONITOR_NATIVE_REFRESH_MIN_INTERVAL_SEC=240
# Hard timeout for native refresh lock recovery (0 disables watchdog).
WORLDMONITOR_NATIVE_REFRESH_HARD_TIMEOUT_MS=180000
# /news command output controls
WORLDMONITOR_NEWS_LIST_MAX_ITEMS=40
# 0 = only refresh on /news force; >0 auto-refreshes /news when cache age exceeds this.
WORLDMONITOR_NEWS_LIST_REFRESH_STALE_SEC=180
# Translate outgoing WorldMonitor headlines to English before sending (/news + feed alerts).
WORLDMONITOR_TRANSLATE_HEADLINES_TO_EN=1
WORLDMONITOR_TRANSLATE_HEADLINES_TIMEOUT_MS=4000
WORLDMONITOR_TRANSLATE_HEADLINES_CONCURRENCY=4
WORLDMONITOR_TRANSLATE_HEADLINES_CACHE_SIZE=5000
# Comma-separated outlet names/domains to skip from WorldMonitor news sources.
WORLDMONITOR_BLOCKED_OUTLETS=Bild,Blick,The Telegraph,Fox News
WORLDMONITOR_BLOCKED_OUTLET_DOMAINS=bild.de,blick.ch,telegraph.co.uk,foxnews.com
WORLDMONITOR_NATIVE_SIGNAL_TIMEOUT_MS=10000
WORLDMONITOR_NATIVE_SIGNALS_MAX_AGE_DAYS=90
WORLDMONITOR_NATIVE_SIGNALS_REFRESH_MIN_INTERVAL_SEC=300
WORLDMONITOR_NATIVE_SEISMIC_REFRESH_MIN_INTERVAL_SEC=900
WORLDMONITOR_NATIVE_ADSB_REFRESH_MIN_INTERVAL_SEC=600
WORLDMONITOR_NATIVE_DISASTER_REFRESH_MIN_INTERVAL_SEC=1800
WORLDMONITOR_NATIVE_MARITIME_REFRESH_MIN_INTERVAL_SEC=1800
WORLDMONITOR_NATIVE_SERVICE_REFRESH_MIN_INTERVAL_SEC=1800
WORLDMONITOR_NATIVE_MACRO_REFRESH_MIN_INTERVAL_SEC=900
WORLDMONITOR_NATIVE_PREDICTION_REFRESH_MIN_INTERVAL_SEC=1200
# Native full-article context enrichment.
# max_per_cycle=0 means "use adaptive auto cap" unless auto cap is explicitly set to 0.
WORLDMONITOR_DEEP_INGEST_ENABLED=1
WORLDMONITOR_DEEP_INGEST_TIMEOUT_MS=15000
WORLDMONITOR_DEEP_INGEST_CONCURRENCY=3
WORLDMONITOR_DEEP_INGEST_STAGE_BUDGET_MS=45000
WORLDMONITOR_DEEP_INGEST_MAX_PER_CYCLE=0
WORLDMONITOR_DEEP_INGEST_AUTO_MAX_PER_CYCLE=12
WORLDMONITOR_DEEP_INGEST_LOOKBACK_HOURS=0
WORLDMONITOR_DEEP_INGEST_RETRY_COOLDOWN_SEC=43200
WORLDMONITOR_DEEP_INGEST_MAX_TEXT_CHARS=18000
WORLDMONITOR_DEEP_INGEST_SUMMARY_MAX_WORDS=140
WORLDMONITOR_DEEP_INGEST_SUMMARY_MAX_CHARS=900
WORLDMONITOR_ALERT_COOLDOWN_SEC=300
WORLDMONITOR_MIN_GLOBAL_RISK_SCORE=60
WORLDMONITOR_MIN_COUNTRY_RISK_SCORE=75
WORLDMONITOR_MIN_GLOBAL_DELTA=12
# Full-report throttling for interval runs (smart/report mode):
# baseline_per_day: first reports/day allowed even without a significant delta.
# max_per_day: hard daily cap on full reports (0 = unlimited).
# min_interval_sec: minimum spacing between full reports (0 = disabled).
# significant_delta: additional full reports beyond baseline require delta >= this value.
WORLDMONITOR_INTERVAL_REPORT_BASELINE_PER_DAY=1
WORLDMONITOR_INTERVAL_REPORT_MAX_PER_DAY=0
WORLDMONITOR_INTERVAL_REPORT_MIN_INTERVAL_SEC=0
WORLDMONITOR_INTERVAL_REPORT_SIGNIFICANT_DELTA=12
WORLDMONITOR_TOP_COUNTRIES=5
WORLDMONITOR_ALERT_CHAT_ID=
WORLDMONITOR_WORKDIR=
WORLDMONITOR_WORKER_TITLE=WorldMonitor Intel
WORLDMONITOR_SUMMARY_MODEL=
WORLDMONITOR_SUMMARY_REASONING=low
WORLDMONITOR_NOTIFY_ERRORS=0
WORLDMONITOR_ALERT_VOICE_ENABLED=1
WORLDMONITOR_ALERT_VOICE_MAX_CHARS=0
WORLDMONITOR_FEED_ALERTS_ENABLED=1
WORLDMONITOR_FEED_ALERTS_MIN_LEVEL=critical
WORLDMONITOR_FEED_ALERTS_INTERVAL_SEC=300
WORLDMONITOR_FEED_ALERTS_MAX_PER_CYCLE=20
WORLDMONITOR_FEED_ALERTS_CHAT_ID=
# Skip very old items even if they appear as newly seen in a feed.
WORLDMONITOR_FEED_ALERTS_MAX_ARTICLE_AGE_HOURS=6
# Size of persistent dedupe memory for previously sent feed alerts (keys + title keys).
WORLDMONITOR_FEED_ALERTS_SENT_KEY_CAP=5000
# Avoid forwarding aggregator wrappers (for example news.google.com links) or document links.
WORLDMONITOR_FEED_ALERTS_SKIP_AGGREGATOR_LINKS=1
WORLDMONITOR_FEED_ALERTS_SKIP_DOCUMENT_LINKS=1
# If deep ingest is enabled, require non-boilerplate article context before forwarding.
WORLDMONITOR_FEED_ALERTS_REQUIRE_CONTEXT_QUALITY=1
# Hours of headline history used by risk scoring and /newsreport snapshots.
WORLDMONITOR_CHECK_LOOKBACK_HOURS=72
WORLDMONITOR_CHECK_MAX_HEADLINES=16
# Hard timeout for /newsreport telemetry fetch stage (0 disables timeout).
WORLDMONITOR_CHECK_FETCH_TIMEOUT_MS=180000
# Run one startup backfill pull to reduce missed-news gaps after downtime.
WORLDMONITOR_STARTUP_CATCHUP_ENABLED=1
# Startup pull reads deeper per feed; normal interval runs still use WORLDMONITOR_NATIVE_FEED_ITEMS_PER_SOURCE.
WORLDMONITOR_STARTUP_CATCHUP_ITEMS_PER_SOURCE=72
# Minimum lookback used for startup catch-up; runtime may increase this when downtime is longer.
WORLDMONITOR_STARTUP_CATCHUP_MIN_LOOKBACK_HOURS=168
WORLDMONITOR_CHECK_TAIWAN_COUNTRY_CODE=TW
# 1 = send an extra "comprehensive report queued" telemetry message for /news, 0 = final report only
WORLDMONITOR_CHECK_ANNOUNCE_QUEUED=0
WORLDMONITOR_CHECK_VOICE_ENABLED=1
WORLDMONITOR_CHECK_VOICE_MAX_CHARS=0
# Daily weather briefing (sent at 06:00 Asia/Taipei, Celsius only)
WEATHER_DAILY_ENABLED=1
# Defaults to TELEGRAM_CHAT_ID when empty
WEATHER_DAILY_CHAT_ID=
WEATHER_DAILY_HOUR=6
WEATHER_DAILY_MINUTE=0
# Optional configured default location. Leave latitude/longitude empty to require /weather location sharing.
WEATHER_DAILY_LOCATION_NAME=
WEATHER_DAILY_LAT=
WEATHER_DAILY_LON=
WEATHER_DAILY_VOICE_ENABLED=1
WEATHER_DAILY_NOTIFY_ERRORS=1
WEATHER_FORECAST_TIMEOUT_MS=12000
WEATHER_GEOCODING_TIMEOUT_MS=10000
CODEX_SESSIONS_DIR=
RESUME_LIST_LIMIT=8
RESUME_SCAN_FILE_LIMIT=240
TELEGRAM_POLL_TIMEOUT_SEC=20
# Telegram DNS preference for Node fetch(): auto | ipv4first | ipv6first | verbatim | off
# auto defaults to ipv4first on Windows (helps avoid IPv6-only timeout paths).
TELEGRAM_DNS_RESULT_ORDER=auto
# Startup getMe retry policy (helps survive transient network timeouts on boot).
TELEGRAM_STARTUP_MAX_ATTEMPTS=8
TELEGRAM_STARTUP_RETRY_BASE_MS=1500
TELEGRAM_STARTUP_RETRY_MAX_MS=15000
STARTUP_MESSAGE=0
SKIP_STALE_UPDATES=1
TELEGRAM_SET_COMMANDS=1
TELEGRAM_COMMAND_SCOPE=all_private_chats
TELEGRAM_FORMAT_BOLD=1
CHAT_LOG_TO_TERMINAL=1
CHAT_LOG_TO_FILE=1
CHAT_LOG_MAX_CHARS=700
CHAT_LOG_FLUSH_INTERVAL_MS=400
CHAT_LOG_BUFFER_MAX_LINES=120
WHISPER_ENABLED=1
WHISPER_VENV_PATH=.venv
WHISPER_MODEL=small
WHISPER_LANGUAGE=auto
WHISPER_MAX_FILE_MB=20
VISION_ENABLED=1
VISION_MAX_FILE_MB=12
VISION_AUTO_FOLLOWUP_SEC=900
TTS_ENABLED=1
TTS_VENV_PATH=.tts-venv
TTS_MODEL=models\\MiraTTS
TTS_REFERENCE_AUDIO=assets\\reference.wav
TTS_FFMPEG_BIN=ffmpeg
TTS_PYTHON=
TTS_SAMPLE_RATE=48000
TTS_OPUS_BITRATE_KBPS=48
TTS_MAX_TEXT_CHARS=1200
TTS_VOICE_MAX_CHARS=320
TTS_VOICE_MAX_SENTENCES=2
TTS_VOICE_MAX_CHUNKS=0
TTS_TIMEOUT_MS=0
TTS_SEND_TEXT=0
TTS_REPLY_TO_VOICE=1
TTS_POSTPROCESS_ENABLED=1
TTS_POSTPROCESS_PRESET=anonymous
# Optional WAV files used by the "starship-comms" preset for start/end radio beeps.
# Relative paths resolve from repo root.
TTS_STARSHIP_BEEP_START=resources\\tts\\a11-comms-start.wav
TTS_STARSHIP_BEEP_END=resources\\tts\\a11-comms-end.wav
TTS_POSTPROCESS_DEBUG=0
MAX_QUEUE_SIZE=0
STATE_WRITE_DEBOUNCE_MS=250
STATE_WRITE_MAX_DELAY_MS=2000
MAX_PROMPT_CHARS=0
MAX_RESPONSE_CHARS=0
PROGRESS_UPDATES_ENABLED=1
PROGRESS_FIRST_UPDATE_SEC=0
PROGRESS_UPDATE_INTERVAL_SEC=30
